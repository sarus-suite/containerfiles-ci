FROM ghcr.io/sarus-suite/containerfiles-ci/ompi:5.0.9-ofi1.22-cuda12.8.1

ARG nccl_tests_version=2.17.9
RUN wget -q -O nccl-tests-${nccl_tests_version}.tar.gz https://github.com/NVIDIA/nccl-tests/archive/refs/tags/v${nccl_tests_version}.tar.gz \
    && tar xf nccl-tests-${nccl_tests_version}.tar.gz \
    && cd nccl-tests-${nccl_tests_version} \
    && MPI=1 make -j$(nproc) \
    && cd .. \
    && rm -rf nccl-tests-${nccl_tests_version}.tar.gz

LABEL org.opencontainers.image.ref.name="nccl-tests"
LABEL org.opencontainers.image.version="${nccl_tests_version}-ompi5.0.9-ofi1.22-cuda12.8.1"
